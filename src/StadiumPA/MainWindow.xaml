<Window x:Class="StadiumPA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:StadiumPA.Converters"
        mc:Ignorable="d"
        Title="STADIUM PA"
        SizeToContent="Height" Width="620" MinWidth="520"
        MaxHeight="{Binding Source={x:Static SystemParameters.MaximizedPrimaryScreenHeight}}"
        Topmost="{Binding AlwaysOnTop}"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Converters -->
        <converters:BoolToPlayingBorderConverter x:Key="PlayingBorderConverter"/>

        <!-- Base button style: dark, touch-friendly, large hit targets -->
        <Style x:Key="TouchButton" TargetType="Button">
            <Setter Property="MinHeight" Value="60"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Large action button (Anthem, Goal, Timeout) -->
        <Style x:Key="LargeActionButton" TargetType="Button" BasedOn="{StaticResource TouchButton}">
            <Setter Property="MinHeight" Value="90"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <!-- Accent button base: reusable template with colored border, background, hover/press states -->
        <ControlTemplate x:Key="AccentButtonTemplate" TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Background"
                            Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Large action button with green glow when playing -->
        <Style x:Key="PlayingActionButton" TargetType="Button" BasedOn="{StaticResource LargeActionButton}">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Tag" Value="#444444"/>
            <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
        </Style>

        <!-- DIM button: amber accent, bright glow when active -->
        <Style x:Key="DimButton" TargetType="Button" BasedOn="{StaticResource TouchButton}">
            <Setter Property="MinHeight" Value="80"/>
            <Setter Property="Background" Value="#3D3520"/>
            <Setter Property="BorderBrush" Value="#AA8833"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Tag" Value="#4D4528"/>
            <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDimActive}" Value="True">
                    <Setter Property="BorderBrush" Value="#FFDD44"/>
                    <Setter Property="Background" Value="#504520"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- FADE OUT button: blue accent, bright glow when active -->
        <Style x:Key="FadeOutButton" TargetType="Button" BasedOn="{StaticResource TouchButton}">
            <Setter Property="MinHeight" Value="80"/>
            <Setter Property="Background" Value="#1E2D3D"/>
            <Setter Property="BorderBrush" Value="#4488CC"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Tag" Value="#263D4D"/>
            <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFadeOutActive}" Value="True">
                    <Setter Property="BorderBrush" Value="#66BBFF"/>
                    <Setter Property="Background" Value="#263D55"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- KILL button: red accent, bright glow when killed -->
        <Style x:Key="KillButton" TargetType="Button" BasedOn="{StaticResource TouchButton}">
            <Setter Property="MinHeight" Value="80"/>
            <Setter Property="Background" Value="#3D1E1E"/>
            <Setter Property="BorderBrush" Value="#CC4444"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Tag" Value="#4D2626"/>
            <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsKilled}" Value="True">
                    <Setter Property="BorderBrush" Value="#FF6666"/>
                    <Setter Property="Background" Value="#552626"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Slider style for dark theme -->
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Section label style -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="12,8,12,4"/>
        </Style>

        <!-- Toggle button for mute / always-on-top -->
        <Style x:Key="ToggleIconButton" TargetType="Button" BasedOn="{StaticResource TouchButton}">
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- Pin button: highlighted border when pinned -->
        <Style x:Key="PinButton" TargetType="Button" BasedOn="{StaticResource ToggleIconButton}">
            <Setter Property="Content" Value="📌"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding AlwaysOnTop}" Value="True">
                    <Setter Property="BorderBrush" Value="#CCAA44"/>
                    <Setter Property="Background" Value="#504020"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding AlwaysOnTop}" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Hotkey badge: small pill overlay shown while Alt is held -->
        <Style x:Key="HotkeyBadge" TargetType="Border">
            <Setter Property="Background" Value="#DD000000"/>
            <Setter Property="BorderBrush" Value="#88FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,-4,-4,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAltHeld}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="8">

        <!-- Title Bar area -->
        <DockPanel Margin="8,6">
            <TextBlock Text="STADIUM PA" FontSize="22" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource PinButton}"
                        Command="{Binding ToggleAlwaysOnTopCommand}"
                        ToolTip="Toggle Always on Top"/>
            </StackPanel>
        </DockPanel>

        <Separator Background="#444444" Margin="8,2"/>

        <!-- ═══ MASTER VOLUME ═══ -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="MASTER VOLUME"/>
        <DockPanel Margin="12,0,12,8">
            <TextBlock Text="{Binding MasterVolumePercent}" Foreground="White" FontSize="16"
                       Width="48" TextAlignment="Right" VerticalAlignment="Center"
                       DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Button Style="{StaticResource ToggleIconButton}"
                    Command="{Binding ToggleMuteCommand}"
                    DockPanel.Dock="Right" Width="60" ToolTip="Ctrl+M">
                <Grid>
                    <ContentPresenter Content="{Binding IsMuted, Converter={x:Static converters:BoolToMuteConverter.Instance}}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Border Style="{StaticResource HotkeyBadge}">
                        <TextBlock Text="Ctrl+M" FontSize="10" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Button>
            <Slider Style="{StaticResource DarkSlider}"
                    Value="{Binding MasterVolumeLevel, Mode=TwoWay}"
                    SmallChange="0.01" LargeChange="0.05"/>
        </DockPanel>

        <Separator Background="#444444" Margin="8,2"/>

        <!-- ═══ AUDIO CONTROLS (DIM / FADE OUT / KILL) ═══ -->
        <UniformGrid Columns="3" Margin="8,4,8,8">
            <Button Style="{StaticResource DimButton}"
                    Command="{Binding DimCommand}">
                <StackPanel>
                    <TextBlock Text="🔉 DIM" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#DDBB44"/>
                    <TextBlock Text="{Binding DimButtonSubtext}" FontSize="11" HorizontalAlignment="Center" Foreground="#AA8833"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource FadeOutButton}"
                    Command="{Binding FadeOutCommand}">
                <StackPanel>
                    <TextBlock Text="🔇 FADE OUT" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#66AAEE"/>
                    <TextBlock Text="↓0% + stop (toggle)" FontSize="11" HorizontalAlignment="Center" Foreground="#4488CC"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource KillButton}"
                    Command="{Binding KillCommand}" ToolTip="Esc">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="⚠ KILL" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FF6666"/>
                        <TextBlock Text="instant off" FontSize="11" HorizontalAlignment="Center" Foreground="#CC4444"/>
                    </StackPanel>
                    <Border Style="{StaticResource HotkeyBadge}">
                        <TextBlock Text="Esc" FontSize="10" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Button>
        </UniformGrid>

        <Separator Background="#444444" Margin="8,2"/>

        <!-- ═══ SPOTIFY ═══ -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="SPOTIFY"/>
        <DockPanel Margin="12,0,12,4">
            <TextBlock Text="{Binding SpotifyVolumePercent}" Foreground="White" FontSize="16"
                       Width="48" TextAlignment="Right" VerticalAlignment="Center"
                       DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Slider Style="{StaticResource DarkSlider}"
                    Value="{Binding SpotifyVolume, Mode=TwoWay}"
                    SmallChange="0.01" LargeChange="0.05"/>
        </DockPanel>
        <UniformGrid Columns="3" Margin="8,0,8,8">
            <Button Style="{StaticResource TouchButton}" ToolTip="Ctrl+Left"
                    Command="{Binding SpotifyPrevCommand}">
                <Grid>
                    <TextBlock Text="⏮ PREV" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Border Style="{StaticResource HotkeyBadge}">
                        <TextBlock Text="Ctrl+←" FontSize="10" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Button>
            <Button Style="{StaticResource TouchButton}" ToolTip="Ctrl+Space"
                    Command="{Binding SpotifyPlayPauseCommand}">
                <Grid>
                    <TextBlock Text="⏯ PLAY / PAUSE" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Border Style="{StaticResource HotkeyBadge}">
                        <TextBlock Text="Ctrl+Space" FontSize="10" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Button>
            <Button Style="{StaticResource TouchButton}" ToolTip="Ctrl+Right"
                    Command="{Binding SpotifyNextCommand}">
                <Grid>
                    <TextBlock Text="⏭ NEXT" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Border Style="{StaticResource HotkeyBadge}">
                        <TextBlock Text="Ctrl+→" FontSize="10" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Button>
        </UniformGrid>

        <Separator Background="#444444" Margin="8,2"/>

        <!-- ═══ ANTHEM / GOAL ═══ -->
        <UniformGrid Columns="2" Margin="8,4,8,8">
            <Button Style="{StaticResource PlayingActionButton}"
                    Command="{Binding AnthemCommand}">
                <Button.BorderBrush>
                    <SolidColorBrush Color="{Binding IsAnthemPlaying, Converter={StaticResource PlayingBorderConverter}}"/>
                </Button.BorderBrush>
                <StackPanel>
                    <TextBlock Text="🏳 NATIONAL" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="ANTHEM" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding AnthemTimeDisplay}" FontSize="12" HorizontalAlignment="Center" Foreground="#777"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource PlayingActionButton}"
                    Command="{Binding GoalCommand}">
                <Button.BorderBrush>
                    <SolidColorBrush Color="{Binding IsGoalPlaying, Converter={StaticResource PlayingBorderConverter}}"/>
                </Button.BorderBrush>
                <StackPanel>
                    <TextBlock Text="🥅 GOAL!" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="CELEBRATION" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding GoalTimeDisplay}" FontSize="12" HorizontalAlignment="Center" Foreground="#777"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <!-- ═══ TIMEOUT ═══ -->
        <Button Style="{StaticResource LargeActionButton}" Margin="8,0,8,12"
                Command="{Binding TimeoutNextSongCommand}"
                ToolTip="Ctrl+T"
                HorizontalContentAlignment="Center">
            <Grid>
                <TextBlock Text="⏱ TIMEOUT — NEXT SONG" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Border Style="{StaticResource HotkeyBadge}">
                    <TextBlock Text="Ctrl+T" FontSize="10" Foreground="White" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Button>

        <!-- Settings -->
        <Separator Background="#444444" Margin="8,2"/>
        <TextBlock Style="{StaticResource SectionLabel}" Text="SETTINGS"/>
        <StackPanel Margin="12,0,12,4">
            <DockPanel Margin="0,2">
                <Button Style="{StaticResource ToggleIconButton}" Content="📂" DockPanel.Dock="Right"
                        Command="{Binding BrowseAnthemFileCommand}" ToolTip="Browse for anthem file"
                        MinWidth="40" MinHeight="30" Padding="6,2"/>
                <TextBlock Foreground="#AAA" FontSize="12" VerticalAlignment="Center">
                    <Run Text="Anthem: "/><Run Text="{Binding AnthemFileDisplay, Mode=OneWay}" Foreground="#DDD"/>
                </TextBlock>
            </DockPanel>
            <DockPanel Margin="0,2">
                <Button Style="{StaticResource ToggleIconButton}" Content="📂" DockPanel.Dock="Right"
                        Command="{Binding BrowseGoalFileCommand}" ToolTip="Browse for goal file"
                        MinWidth="40" MinHeight="30" Padding="6,2"/>
                <TextBlock Foreground="#AAA" FontSize="12" VerticalAlignment="Center">
                    <Run Text="Goal: "/><Run Text="{Binding GoalFileDisplay, Mode=OneWay}" Foreground="#DDD"/>
                </TextBlock>
            </DockPanel>
            <!-- Dim Level & Fade Duration -->
            <DockPanel Margin="0,6,0,2">
                <TextBlock Text="{Binding DimLevelPercent}" Foreground="White" FontSize="13"
                           Width="40" TextAlignment="Right" VerticalAlignment="Center"
                           DockPanel.Dock="Right"/>
                <TextBlock Text="Dim Level:" Foreground="#AAA" FontSize="12"
                           VerticalAlignment="Center" Width="90"/>
                <Slider Minimum="0.01" Maximum="0.50" SmallChange="0.01" LargeChange="0.05"
                        Value="{Binding DimLevel, Mode=TwoWay}"
                        Style="{StaticResource DarkSlider}"/>
            </DockPanel>
            <DockPanel Margin="0,2">
                <TextBlock Text="{Binding FadeDurationDisplay}" Foreground="White" FontSize="13"
                           Width="40" TextAlignment="Right" VerticalAlignment="Center"
                           DockPanel.Dock="Right"/>
                <TextBlock Text="Fade Speed:" Foreground="#AAA" FontSize="12"
                           VerticalAlignment="Center" Width="90"/>
                <Slider Minimum="0.2" Maximum="3.0" SmallChange="0.1" LargeChange="0.5"
                        Value="{Binding FadeDurationSeconds, Mode=TwoWay}"
                        Style="{StaticResource DarkSlider}"/>
            </DockPanel>
        </StackPanel>

        <!-- Status Message (hidden when empty) -->
        <TextBlock Text="{Binding StatusMessage}" Foreground="#FF8866" FontSize="12"
                   Margin="12,0,12,4" TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Pre-Game Checklist (compact horizontal row) -->
        <Separator Background="#444444" Margin="8,2"/>
        <WrapPanel Margin="12,2,12,8" Orientation="Horizontal">
            <TextBlock Text="CHECKLIST:" FontSize="10" FontWeight="SemiBold" Foreground="#888888"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding AnthemStatusText}" ToolTip="{Binding AnthemStatusText}"
                       FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#66CC66"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnthemReady}" Value="False">
                                <Setter Property="Foreground" Value="#FF8866"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding GoalStatusText}" ToolTip="{Binding GoalStatusText}"
                       FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#66CC66"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGoalReady}" Value="False">
                                <Setter Property="Foreground" Value="#FF8866"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding SpotifyStatusText}" ToolTip="{Binding SpotifyStatusText}"
                       FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#66CC66"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSpotifyReady}" Value="False">
                                <Setter Property="Foreground" Value="#DDAA44"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding VolumeStatusText}" ToolTip="{Binding VolumeStatusText}"
                       FontSize="11" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#66CC66"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsVolumeReady}" Value="False">
                                <Setter Property="Foreground" Value="#DDAA44"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </WrapPanel>

    </StackPanel>
    </ScrollViewer>
</Window>
